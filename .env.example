# Credenciales de Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
VITE_SUPABASE_ANON_KEY="TU_ANON_KEY"

# --- Solo para las funciones de servidor en /api (Vercel) ---
# NUNCA con prefijo VITE_: no deben llegar al navegador.

