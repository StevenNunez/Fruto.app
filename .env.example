SUPABASE_SERVICE_ROLE_KEY="TU_SERVICE_ROLE_KEY"

# Mercado Pago → Tus integraciones → Credenciales (modo Prueba primero)
MP_ACCESS_TOKEN="TU_ACCESS_TOKEN"
MP_PUBLIC_KEY="TU_PUBLIC_KEY"
